# Database
DB_PASSWORD=secure_password_here
DATABASE_URL=postgresql://iebc_admin:secure_password_here@localhost:5432/election_transparency

# Redis
REDIS_URL=redis://localhost:6379

# AWS (for Textract OCR)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Safaricom Daraja API
SAFARICOM_CONSUMER_KEY=your_consumer_key
SAFARICOM_CONSUMER_SECRET=your_consumer_secret
SAFARICOM_PASSKEY=your_passkey
SAFARICOM_SHORTCODE=174379
SAFARICOM_BASE_URL=https://sandbox.safaricom.co.ke

# IPFS
IPFS_URL=http://localhost:5001
IPFS_GATEWAY=http://localhost:8080

# Security
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
ENCRYPTION_KEY=your_32_char_encryption_key

# Blockchain (Optional - for audit trail)
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/your_project_id
BLOCKCHAIN_PRIVATE_KEY=your_wallet_private_key